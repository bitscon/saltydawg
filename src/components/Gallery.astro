---
import { gallery } from '../data/site';
---

<section
  id="gallery"
  style="background: #0a1628; padding: 80px 0;"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="text-center mb-12 fade-up">
      <p class="section-label">Photo Proof</p>
      <h2 class="section-title text-white">
        The <span style="color:#f5a800;">Salty Dawg</span> Life
      </h2>
      <p class="mt-4" style="color:rgba(255,255,255,0.6); font-family:'Barlow Condensed',sans-serif; font-size:1.1rem;">
        Real trips. Real catches. Real good vibes on the Merrimack.
      </p>
    </div>

    <!-- Masonry-style grid -->
    <div
      class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4"
      style="grid-auto-rows: 220px;"
    >
      {gallery.map((img, i) => (
        <button
          type="button"
          class={`gallery-img gallery-trigger ${i === 0 ? 'row-span-2' : ''}`}
          style={i === 0 ? 'grid-row: span 2;' : ''}
          data-flyer-src={img.src}
          data-flyer-alt={img.alt}
          aria-label={`Open flyer: ${img.alt}`}
        >
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            style="width:100%; height:100%; object-fit:cover; display:block;"
            onerror="this.style.display='none'; this.closest('.gallery-img').style.background='linear-gradient(135deg,#0f3460,#0d1b3e)'; this.closest('.gallery-img').setAttribute('aria-label','Image placeholder — add photo to /public/assets/');"
          />
          <span class="gallery-img__label" aria-hidden="true">View Flyer</span>
        </button>
      ))}
    </div>

    <!-- Caption -->
    <p
      class="text-center mt-8 text-sm fade-up"
      style="color:rgba(255,255,255,0.4); font-family:'Barlow Condensed',sans-serif; letter-spacing:0.08em; text-transform:uppercase;"
    >
      Join the crew — <a
        href="https://www.facebook.com/groups/1410987557385865"
        target="_blank"
        rel="noopener noreferrer"
        style="color:#f5a800; text-decoration:none;"
      >Salty Dawg II Facebook Group</a>
    </p>

  </div>

  <div
    id="gallery-lightbox"
    class="gallery-lightbox hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="gallery-lightbox-title"
  >
    <button
      type="button"
      class="gallery-lightbox__backdrop"
      data-gallery-close
      aria-label="Close flyer"
    ></button>

    <div class="gallery-lightbox__panel" role="document">
      <div class="gallery-lightbox__topbar">
        <p id="gallery-lightbox-title">Salty Dawg II Flyer</p>
        <button
          type="button"
          class="gallery-lightbox__close"
          data-gallery-close
          aria-label="Close flyer"
        >
          Close
        </button>
      </div>

      <img
        id="gallery-lightbox-img"
        src=""
        alt=""
        class="gallery-lightbox__img"
      />
    </div>
  </div>
</section>

<script>
  const lightbox = document.getElementById('gallery-lightbox')!;
  const lightboxImg = document.getElementById('gallery-lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('gallery-lightbox-title')!;
  const closeButtons = document.querySelectorAll<HTMLElement>('[data-gallery-close]');
  let lastFocusedTrigger: HTMLElement | null = null;

  function openFlyer(trigger: HTMLElement) {
    const src = trigger.dataset.flyerSrc;
    const alt = trigger.dataset.flyerAlt || 'Salty Dawg II flyer';
    if (!src) return;

    lastFocusedTrigger = trigger;
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightboxTitle.textContent = alt;
    lightbox.classList.remove('hidden');
    document.body.classList.add('gallery-lightbox-open');
    lightbox.querySelector<HTMLElement>('.gallery-lightbox__close')?.focus();
  }

  function closeFlyer() {
    lightbox.classList.add('hidden');
    document.body.classList.remove('gallery-lightbox-open');
    lightboxImg.src = '';
    lastFocusedTrigger?.focus();
  }

  document.querySelectorAll<HTMLElement>('.gallery-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => openFlyer(trigger));
  });

  closeButtons.forEach((button) => {
    button.addEventListener('click', closeFlyer);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !lightbox.classList.contains('hidden')) {
      closeFlyer();
    }
  });
</script>
