---
// No real testimonials confirmed from assets.
// These are styled placeholder cards — DO NOT present as real reviews.
// Owner should replace with actual customer reviews.

const placeholders = [
  {
    stars: 5,
    quote: "[Review or testimonial goes here. Keep it short and impactful. Replace with a real customer review.]",
    name: "[Guest Name Placeholder]",
  },
  {
    stars: 5,
    quote: "[Review or testimonial goes here. Keep it short and impactful. Replace with a real customer review.]",
    name: "[Guest Name Placeholder]",
  },
  {
    stars: 5,
    quote: "[Review or testimonial goes here. Keep it short and impactful. Replace with a real customer review.]",
    name: "[Guest Name Placeholder]",
  },
];
---

<section
  style="background: #0d1b3e; padding: 80px 0; position:relative; overflow:hidden;"
>
  <!-- Gold glow background -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at 50% 100%, rgba(245,168,0,0.08) 0%, transparent 70%); pointer-events:none;"
    aria-hidden="true"
  ></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">

    <div class="text-center mb-12 fade-up">
      <p class="section-label">Reviews & Testimonials</p>
      <h2 class="section-title text-white">
        What People <span style="color:#f5a800;">Are Saying</span>
      </h2>
      <!-- Owner note - visible in dev, hidden in production via opacity -->
      <p
        class="mt-3 text-xs inline-block px-4 py-2 rounded"
        style="background:rgba(245,168,0,0.1); border:1px solid rgba(245,168,0,0.3); color:#f5a800; font-family:'Barlow',sans-serif;"
      >
        ⚠️ Owner: Replace these placeholders with real customer reviews.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {placeholders.map(({ stars, quote, name }, i) => (
        <div
          class="testimonial-card p-6 rounded-lg"
          style="background:linear-gradient(145deg,#091428,#0a1a35); border:1px solid rgba(245,168,0,0.2);"
        >
          <!-- Stars -->
          <div class="flex gap-1 mb-3">
            {Array.from({ length: stars }).map(() => (
              <span style="color:#f5a800; font-size:1.1rem;" aria-hidden="true">★</span>
            ))}
          </div>

          <!-- Quote mark -->
          <div
            class="mb-3"
            style="font-size:3rem; line-height:1; color:rgba(245,168,0,0.25); font-family:Georgia,serif; leading-none;"
            aria-hidden="true"
          >&ldquo;</div>

          <p
            style="font-family:'Barlow',sans-serif; color:rgba(255,255,255,0.7); font-style:italic; line-height:1.6; margin-bottom:1rem;"
          >
            {quote}
          </p>

          <p
            style="font-family:'Barlow Condensed',sans-serif; font-weight:700; color:#f5a800; font-size:0.9rem; letter-spacing:0.05em; text-transform:uppercase;"
          >
            — {name}
          </p>
        </div>
      ))}
    </div>

    <!-- Facebook social proof -->
    <div class="text-center mt-12 fade-up">
      <p
        class="mb-4"
        style="font-family:'Barlow Condensed',sans-serif; font-size:1.1rem; color:rgba(255,255,255,0.6);"
      >
        See what the crew is up to — join the community:
      </p>
      <a
        href="https://www.facebook.com/groups/1410987557385865"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline inline-flex items-center gap-2"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Salty Dawg II Facebook Group
      </a>
    </div>

  </div>
</section>
