---
import { site } from '../data/site';
---

<header
  id="site-header"
  class="fixed left-0 right-0 top-0 z-50 border-b border-gold/20 bg-dark/90 shadow-[0_12px_40px_rgba(0,0,0,0.28)] backdrop-blur-xl transition-all duration-300"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-3 px-4 sm:px-6 md:h-[4.5rem]">

    <!-- Logo -->
    <a
      href="#top"
      class="group flex min-w-0 shrink-0 items-center rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold"
      aria-label="Salty Dawg II home"
    >
      <img
        src="/assets/logo-main-transparent.png"
        alt="Salty Dawg II logo"
        class="h-9 w-auto max-w-[10.5rem] object-contain drop-shadow-[0_4px_14px_rgba(245,168,0,0.34)] transition-transform duration-200 group-hover:scale-[1.02] sm:h-10 sm:max-w-[12.5rem] md:h-12 md:max-w-[15rem]"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <span
        class="hidden items-center whitespace-nowrap"
        style="font-family:'Bebas Neue',sans-serif; font-size:1.5rem; color:#f5a800; text-shadow:0 0 10px rgba(245,168,0,0.6);"
      >
        Salty Dawg II
      </span>
    </a>

    <!-- Nav (desktop) -->
    <nav class="hidden items-center gap-6 md:flex lg:gap-8" aria-label="Main navigation">
      {[
        { label: 'Trips',   href: '#trips'   },
        { label: 'Gallery', href: '#gallery' },
        { label: 'About',   href: '#about'   },
        { label: 'FAQ',     href: '#faq'     },
        { label: 'Contact', href: '#contact' },
      ].map(({ label, href }) => (
        <a
          href={href}
          class="rounded-sm text-sm font-bold uppercase text-white/[0.82] transition-colors duration-150 hover:text-gold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold"
          style="font-family:'Barlow Condensed',sans-serif; letter-spacing:0.12em;"
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <!-- CTA -->
      <a
        href={site.phoneHref}
        class="btn-gold max-sm:!hidden px-3 py-2 text-sm sm:px-4 md:px-5"
        aria-label="Call or text to book Salty Dawg II"
      >
        <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C9.61 21 3 14.39 3 6a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
        </svg>
        <span class="hidden sm:inline">Call&nbsp;/&nbsp;Text to Book</span>
        <span class="sm:hidden">Book</span>
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-toggle"
        class="mobile-menu-button fixed right-4 top-3 rounded-sm border border-gold/40 bg-dark/80 p-2 text-gold shadow-[0_8px_24px_rgba(0,0,0,0.35)] backdrop-blur-md transition-colors hover:bg-gold/15 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav drawer -->
  <div
    id="mobile-nav"
    class="hidden flex-col gap-1 border-t border-gold/15 bg-dark/[0.98] px-4 pb-4 md:hidden"
  >
    {[
      { label: 'Trips',   href: '#trips'   },
      { label: 'Gallery', href: '#gallery' },
      { label: 'About',   href: '#about'   },
      { label: 'FAQ',     href: '#faq'     },
      { label: 'Contact', href: '#contact' },
    ].map(({ label, href }) => (
      <a
        href={href}
        class="mobile-nav-link block border-b py-3 font-bold uppercase tracking-wider text-white transition-colors hover:text-gold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold"
        style="font-family:'Barlow Condensed',sans-serif; border-color:rgba(245,168,0,0.15);"
      >
        {label}
      </a>
    ))}
    <a
      href={site.phoneHref}
      class="btn-gold mt-3 justify-center"
    >
      <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C9.61 21 3 14.39 3 6a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
      </svg>
      Call / Text to Book
    </a>
  </div>
</header>

<!-- Spacer so content doesn't hide behind fixed header -->
<div class="h-16 md:h-[4.5rem]"></div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle')!;
  const nav    = document.getElementById('mobile-nav')!;

  toggle.addEventListener('click', () => {
    const isOpen = !nav.classList.contains('hidden');
    nav.classList.toggle('hidden', isOpen);
    nav.style.display = isOpen ? 'none' : 'flex';
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.add('hidden');
      nav.style.display = 'none';
      toggle.setAttribute('aria-expanded', 'false');
    });
  });

  // Scroll: add stronger bg on scroll
  const header = document.getElementById('site-header')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header.classList.add('bg-dark/[0.98]', 'border-gold/40');
      header.classList.remove('bg-dark/90', 'border-gold/20');
    } else {
      header.classList.add('bg-dark/90', 'border-gold/20');
      header.classList.remove('bg-dark/[0.98]', 'border-gold/40');
    }
  }, { passive: true });
</script>
