---
import { site } from '../data/site';
---

<section
  id="top"
  class="relative isolate overflow-hidden bg-dark"
>
  <div class="absolute inset-0 -z-30 bg-[radial-gradient(circle_at_18%_22%,rgba(15,52,96,0.95),transparent_34%),radial-gradient(circle_at_85%_18%,rgba(245,168,0,0.18),transparent_26%),linear-gradient(135deg,#060b14_0%,#0b1833_42%,#0f3460_100%)]" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-20 opacity-[0.16] [background-image:linear-gradient(115deg,transparent_0%,rgba(255,255,255,0.18)_48%,transparent_52%),repeating-linear-gradient(170deg,rgba(255,255,255,0.16)_0_1px,transparent_1px_18px)] [background-size:220px_90px,100%_100%]" aria-hidden="true"></div>
  <div class="absolute -right-24 top-20 -z-10 h-64 w-64 rounded-full bg-gold/20 blur-3xl md:h-96 md:w-96" aria-hidden="true"></div>
  <div class="absolute left-0 top-0 -z-10 h-48 w-24 bg-gold/20 blur-2xl [clip-path:polygon(0_0,100%_0,38%_100%,0_72%)]" aria-hidden="true"></div>

  <div class="relative mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 sm:py-10 md:py-16 lg:py-20">
    <div class="grid items-center gap-8 md:grid-cols-[0.94fr_1.06fr] lg:gap-12">

      <!-- Left: Text content -->
      <div class="order-2 md:order-1">
        <div id="hero-logo" class="mb-5 flex items-center gap-3">
          <img
            src="/assets/logo-main-transparent.png"
            alt="Salty Dawg II logo"
            class="h-auto w-40 max-w-full drop-shadow-[0_6px_20px_rgba(0,0,0,0.7)] sm:w-56 md:w-64"
            onerror="this.onerror=null; this.style.display='none';"
          />
          <div class="hidden h-px flex-1 bg-gradient-to-r from-gold/70 to-transparent sm:block" aria-hidden="true"></div>
        </div>

        <!-- Headline -->
        <h1
          id="hero-headline"
          class="max-w-[11ch] font-display text-[clamp(2.85rem,14.5vw,5.65rem)] uppercase leading-[0.92] text-white drop-shadow-[0_5px_24px_rgba(0,0,0,0.72)] md:text-[clamp(4.4rem,7.3vw,6.4rem)] md:leading-[0.9]"
        >
          This Is Not Your <span class="text-gold">Average</span> Boat Ride.
        </h1>

        <!-- Sub-headline -->
        <div id="hero-sub" class="mt-5 max-w-2xl">
          <p class="text-balance font-heading text-xl font-semibold leading-snug text-white/[0.86] sm:text-2xl">
            Striper trips, sunset cruises, and private Merrimack River adventures built for big fish, good people, and better stories.
          </p>
          <p class="mt-3 inline-flex border-l-4 border-gold pl-3 font-heading text-lg font-bold uppercase tracking-[0.14em] text-gold sm:text-xl">
            All Gas. No Brakes. Full Send.
          </p>
        </div>

        <!-- CTA buttons -->
        <div id="hero-cta" class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
          <a href={site.phoneHref} class="btn-gold justify-center px-6 py-3.5 text-base sm:text-lg">
            <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C9.61 21 3 14.39 3 6a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
            </svg>
            Call / Text to Book
          </a>
          <a href="#trips" class="btn-outline justify-center px-6 py-3.5 text-base sm:text-lg">
            View Trips
          </a>
        </div>

        <!-- Proof bullets -->
        <ul id="hero-bullets" class="mt-7 grid gap-2 sm:grid-cols-3 md:max-w-2xl">
          {['Striper Trips', 'Sunset Cruises', 'Private Charters'].map((text) => (
            <li class="flex items-center gap-2 rounded-sm border border-white/10 bg-white/[0.06] px-3 py-2 font-heading text-sm font-bold uppercase tracking-[0.12em] text-white/[0.86] shadow-[inset_0_1px_0_rgba(255,255,255,0.08)]">
              <span class="h-2 w-2 shrink-0 rounded-full bg-gold shadow-[0_0_14px_rgba(245,168,0,0.75)]" aria-hidden="true"></span>
              {text}
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: Hero image -->
      <div id="hero-image" class="order-1 md:order-2">
        <div class="relative mx-auto max-w-2xl md:mr-0">
          <div class="absolute -inset-3 rotate-[-2deg] rounded-md border border-gold/25 bg-gold/10 shadow-[0_0_55px_rgba(245,168,0,0.18)]" aria-hidden="true"></div>
          <div class="relative overflow-hidden rounded-md border-2 border-gold/60 bg-ocean shadow-[0_24px_70px_rgba(0,0,0,0.58)] md:rotate-[1.4deg]">
            <div class="absolute inset-0 z-10 bg-[linear-gradient(180deg,rgba(6,11,20,0)_45%,rgba(6,11,20,0.18)_100%),radial-gradient(circle_at_72%_18%,rgba(245,168,0,0.18),transparent_32%)]" aria-hidden="true"></div>
            <img
              src="/assets/flyer-monster-catch.jpg"
              alt="Salty Dawg II crew holding a giant striped bass on the Merrimack River"
              class="block aspect-[16/9] h-full w-full object-cover"
              style="object-position: 50% 56%;"
              fetchpriority="high"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div
              class="img-placeholder hidden aspect-[16/11] items-center justify-center bg-[linear-gradient(135deg,#0f3460,#0d1b3e)] font-display text-2xl uppercase tracking-[0.12em] text-gold/50"
            >
              Add Hero Image
            </div>
          </div>
          <div class="absolute -bottom-3 left-4 z-20 rounded-sm border border-gold/40 bg-dark/90 px-3 py-2 font-heading text-sm font-bold uppercase tracking-[0.16em] text-gold shadow-[0_10px_25px_rgba(0,0,0,0.45)] sm:left-6 sm:text-base">
            Merrimack River
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Drip bottom edge -->
  <div
    class="absolute bottom-0 left-0 right-0 z-10"
    aria-hidden="true"
    style="height:48px; background:linear-gradient(to bottom, transparent, #060b14);"
  ></div>
</section>
