---
import { site } from '../data/site';
---

<!-- Final CTA Banner -->
<section
  id="contact"
  class="relative overflow-hidden"
  style="background: linear-gradient(135deg, #0d1b3e 0%, #0a3060 40%, #0d1b3e 100%); padding: 80px 0;"
>
  <!-- Background image overlay -->
  <div
    class="absolute inset-0"
    style="background-image: url('/assets/flyer-booze-cruise.jpg'); background-size:cover; background-position:center; opacity:0.15;"
    aria-hidden="true"
  ></div>

  <!-- Gold glow -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at 50% 50%, rgba(245,168,0,0.12) 0%, transparent 70%); pointer-events:none;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">

    <!-- WAC sticker -->
    <img
      src="/assets/logo-sticker.png"
      alt="Salty Dawg II sticker"
      class="mx-auto mb-6 w-24 opacity-80"
      style="filter: drop-shadow(0 0 20px rgba(245,168,0,0.4));"
      onerror="this.style.display='none';"
    />

    <!-- Headline -->
    <h2
      style="font-family:'Bebas Neue','Arial Black',sans-serif; font-size:clamp(2.8rem,7vw,5rem); line-height:1; text-transform:uppercase; text-shadow:0 4px 20px rgba(0,0,0,0.8);"
    >
      <span style="color:#ffffff;">Ready to Book Your</span><br/>
      <span style="color:#f5a800; text-shadow:0 0 30px rgba(245,168,0,0.6);">Salty Dawg Experience?</span>
    </h2>

    <p
      class="mt-5 text-lg md:text-xl"
      style="font-family:'Barlow Condensed',sans-serif; color:rgba(255,255,255,0.8); letter-spacing:0.03em;"
    >
      Limited spots. Don't get left at the dock.
    </p>

    <!-- Trust points -->
    <ul class="mt-6 flex flex-wrap justify-center gap-4 text-sm mb-8">
      {[
        "[Confirm License / Insurance]",
        "Top-Rated Charter Experience",
        "Safety &amp; Fun Come First",
        "Memories That Last",
      ].map((point) => (
        <li
          class="flex items-center gap-2"
          style="font-family:'Barlow Condensed',sans-serif; color:rgba(255,255,255,0.75); font-weight:600; letter-spacing:0.05em; text-transform:uppercase;"
        >
          <span style="color:#f5a800;">✓</span>
          <span set:html={point} />
        </li>
      ))}
    </ul>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={site.phoneHref}
        class="btn-gold text-lg px-8 py-4"
      >
        <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C9.61 21 3 14.39 3 6a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
        </svg>
        Call / Text to Book
      </a>
      <a
        href={site.facebookUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline text-base px-6 py-4"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Join the Facebook Group
      </a>
    </div>

  </div>
</section>

<!-- Footer -->
<footer
  style="background: #040810; padding: 40px 0 20px; border-top: 1px solid rgba(245,168,0,0.1);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-3 gap-8 mb-8">

      <!-- Logo + tagline -->
      <div>
        <img
          src="/assets/logo-main.png"
          alt="Salty Dawg II"
          class="h-12 mb-3"
          style="filter: drop-shadow(0 0 8px rgba(245,168,0,0.4));"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
        />
        <span
          style="display:none; font-family:'Bebas Neue',sans-serif; font-size:1.6rem; color:#f5a800;"
        >
          Salty Dawg II
        </span>
        <p style="font-family:'Barlow',sans-serif; color:rgba(255,255,255,0.45); font-size:0.85rem; line-height:1.6;">
          Merrimack River fishing charters &amp; river adventures.<br/>
          This is not your average boat ride.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <p style="font-family:'Barlow Condensed',sans-serif; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#f5a800; margin-bottom:0.75rem; font-size:0.85rem;">
          Quick Links
        </p>
        <ul class="space-y-2">
          {[
            { label: 'Trips', href: '#trips' },
            { label: 'Gallery', href: '#gallery' },
            { label: 'About', href: '#about' },
            { label: 'FAQ', href: '#faq' },
          ].map(({ label, href }) => (
            <li>
              <a
                href={href}
                style="font-family:'Barlow',sans-serif; color:rgba(255,255,255,0.5); font-size:0.9rem; text-decoration:none; transition:color 0.15s;"
                onmouseover="this.style.color='#f5a800'"
                onmouseout="this.style.color='rgba(255,255,255,0.5)'"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & social -->
      <div>
        <p style="font-family:'Barlow Condensed',sans-serif; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#f5a800; margin-bottom:0.75rem; font-size:0.85rem;">
          Get In Touch
        </p>
        <p style="font-family:'Barlow',sans-serif; color:rgba(255,255,255,0.5); font-size:0.9rem; margin-bottom:0.5rem;">
          📞 {site.phone}
        </p>
        <p style="font-family:'Barlow',sans-serif; color:rgba(255,255,255,0.5); font-size:0.9rem; margin-bottom:1.25rem;">
          📍 {site.location}
        </p>

        <!-- Social icons -->
        <div class="flex gap-4">
          <a
            href={site.facebookUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Salty Dawg II on Facebook"
            style="color:rgba(255,255,255,0.4); transition:color 0.15s;"
            onmouseover="this.style.color='#f5a800'"
            onmouseout="this.style.color='rgba(255,255,255,0.4)'"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href={site.instagramUrl}
            aria-label="Salty Dawg II on Instagram"
            style="color:rgba(255,255,255,0.4); transition:color 0.15s;"
            onmouseover="this.style.color='#f5a800'"
            onmouseout="this.style.color='rgba(255,255,255,0.4)'"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href={site.tiktokUrl}
            aria-label="Salty Dawg II on TikTok"
            style="color:rgba(255,255,255,0.4); transition:color 0.15s;"
            onmouseover="this.style.color='#f5a800'"
            onmouseout="this.style.color='rgba(255,255,255,0.4)'"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.16 8.16 0 004.77 1.52V6.76a4.85 4.85 0 01-1-.07z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div
      class="pt-6 flex flex-col sm:flex-row justify-between items-center gap-2"
      style="border-top: 1px solid rgba(255,255,255,0.06);"
    >
      <p style="font-family:'Barlow',sans-serif; color:rgba(255,255,255,0.25); font-size:0.8rem;">
        &copy; {new Date().getFullYear()} Salty Dawg II. All Rights Reserved.
      </p>
      <p style="font-family:'Bebas Neue',sans-serif; color:rgba(245,168,0,0.35); font-size:0.85rem; letter-spacing:0.1em;">
        ALL GAS. NO BRAKES. FULL SEND.
      </p>
    </div>

  </div>
</footer>
