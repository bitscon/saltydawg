---
import { site } from '../data/site';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(6,11,20,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(245,168,0,0.15);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16 md:h-18">

    <!-- Logo -->
    <a href="#top" class="flex items-center shrink-0" aria-label="Salty Dawg II — Home">
      <img
        src="/assets/logo-main.png"
        alt="Salty Dawg II logo"
        class="h-10 md:h-12 w-auto"
        style="filter: drop-shadow(0 0 8px rgba(245,168,0,0.5));"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <span
        class="hidden items-center"
        style="font-family:'Bebas Neue',sans-serif; font-size:1.5rem; color:#f5a800; text-shadow:0 0 10px rgba(245,168,0,0.6);"
      >
        Salty Dawg II
      </span>
    </a>

    <!-- Nav (desktop) -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {[
        { label: 'Trips',   href: '#trips'   },
        { label: 'Gallery', href: '#gallery' },
        { label: 'About',   href: '#about'   },
        { label: 'FAQ',     href: '#faq'     },
        { label: 'Contact', href: '#contact' },
      ].map(({ label, href }) => (
        <a
          href={href}
          class="text-sm font-semibold uppercase tracking-widest text-white hover:text-yellow-400 transition-colors duration-150"
          style="font-family:'Barlow Condensed',sans-serif; letter-spacing:0.12em;"
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <a
      href={site.phoneHref}
      class="btn-gold text-sm px-4 py-2 md:px-5 md:py-2"
      style="font-size:0.9rem;"
    >
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C9.61 21 3 14.39 3 6a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.45.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"/>
      </svg>
      Call&nbsp;/&nbsp;Text to Book
    </a>

    <!-- Mobile menu toggle -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden ml-3 p-2 rounded"
      style="background:rgba(245,168,0,0.1); border:1px solid rgba(245,168,0,0.3);"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile nav drawer -->
  <div
    id="mobile-nav"
    class="md:hidden hidden flex-col gap-1 px-4 pb-4"
    style="background: rgba(6,11,20,0.98);"
  >
    {[
      { label: 'Trips',   href: '#trips'   },
      { label: 'Gallery', href: '#gallery' },
      { label: 'About',   href: '#about'   },
      { label: 'FAQ',     href: '#faq'     },
      { label: 'Contact', href: '#contact' },
    ].map(({ label, href }) => (
      <a
        href={href}
        class="block py-3 border-b text-white font-semibold uppercase tracking-wider hover:text-yellow-400 transition-colors mobile-nav-link"
        style="font-family:'Barlow Condensed',sans-serif; border-color:rgba(245,168,0,0.15);"
      >
        {label}
      </a>
    ))}
    <a
      href={site.phoneHref}
      class="btn-gold mt-3 justify-center"
    >
      📞 Call / Text to Book
    </a>
  </div>
</header>

<!-- Spacer so content doesn't hide behind fixed header -->
<div class="h-16 md:h-18"></div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle')!;
  const nav    = document.getElementById('mobile-nav')!;

  toggle.addEventListener('click', () => {
    const isOpen = !nav.classList.contains('hidden');
    nav.classList.toggle('hidden', isOpen);
    nav.style.display = isOpen ? 'none' : 'flex';
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.add('hidden');
      nav.style.display = 'none';
      toggle.setAttribute('aria-expanded', 'false');
    });
  });

  // Scroll: add stronger bg on scroll
  const header = document.getElementById('site-header')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header.style.background = 'rgba(6,11,20,0.98)';
      header.style.borderBottomColor = 'rgba(245,168,0,0.3)';
    } else {
      header.style.background = 'rgba(6,11,20,0.92)';
      header.style.borderBottomColor = 'rgba(245,168,0,0.15)';
    }
  }, { passive: true });
</script>
